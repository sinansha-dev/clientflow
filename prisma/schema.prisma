generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DEVELOPER
  CLIENT
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  firstName     String
  lastName      String
  email         String         @unique
  password      String
  avatar        String?
  phone         String?
  role          Role           @default(CLIENT)
  status        UserStatus     @default(ACTIVE)
  emailVerified Boolean        @default(false)
  lastLogin     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  refreshTokens RefreshToken[]
  resetTokens   PasswordResetToken[]
  managedClients Client[]       @relation("ManagerClients")
  clientNotes    ClientNote[]
  projectTeams   ProjectTeam[]
  managedProjects Project[]     @relation("ProjectManager")
  projectNotes   ProjectNote[]
  assignedTasks   Task[]         @relation("TaskAssignees")
  taskComments    TaskComment[]
  taskAttachments TaskAttachment[] @relation("TaskAttachmentUploader")

  // Workforce Management fields (Phase 5)
  employeeId         String?
  jobTitle           String?
  department         String?
  skills             String[]
  hourlyRate         Float?
  employmentType     String?         // Full-Time, Part-Time, Freelancer, Contractor
  joinDate           DateTime?
  managerId          String?         @db.Uuid
  manager            User?           @relation("UserManager", fields: [managerId], references: [id])
  subordinates       User[]          @relation("UserManager")
  availabilityStatus String          @default("OFFLINE") // Available, Busy, In Meeting, On Leave, Offline
  timezone           String          @default("UTC")

  timeLogs           TimeLog[]
  meetingsOrganized  Meeting[]       @relation("OrganizerMeetings")
  meetingsAttending  MeetingParticipant[]
  calendarEvents     CalendarEvent[]

  @@index([email])
  @@index([role])
  @@index([deletedAt])
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  replacedByTokenHash String?

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Client {
  id                String           @id @default(uuid()) @db.Uuid
  companyName       String           @unique
  companyLogo       String?
  industry          String
  website           String
  email             String
  phone             String
  taxNumber         String?
  billingAddress    String
  shippingAddress   String
  country           String
  state             String
  city              String
  postalCode        String
  currency          String           @default("USD")
  timezone          String           @default("UTC")
  status            String           @default("ACTIVE")
  source            String?
  assignedManagerId String?          @db.Uuid
  assignedManager   User?            @relation("ManagerClients", fields: [assignedManagerId], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  archivedAt        DateTime?
  deletedAt         DateTime?

  contacts        ClientContact[]
  notes           ClientNote[]
  files           ClientFile[]
  activities      ClientActivity[]
  projects        Project[]

  @@index([deletedAt])
  @@index([archivedAt])
  @@index([companyName])
}

model ClientContact {
  id             String   @id @default(uuid()) @db.Uuid
  clientId       String   @db.Uuid
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name           String
  position       String
  email          String
  phone          String
  whatsapp       String?
  primaryContact Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([clientId])
}

model ClientNote {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @db.Uuid
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  note      String   @db.Text
  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([userId])
}

model ClientFile {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @db.Uuid
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  type      String
  size      Int
  url       String
  createdAt DateTime @default(now())

  @@index([clientId])
}

model ClientActivity {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @db.Uuid
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type      String
  description String
  createdAt DateTime @default(now())

  @@index([clientId])
}

model Project {
  id                String           @id @default(uuid()) @db.Uuid
  clientId          String           @db.Uuid
  client            Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectName       String
  projectCode       String           @unique
  description       String
  status            String           @default("PLANNING")
  priority          String           @default("MEDIUM")
  budget            Float
  estimatedHours    Float
  actualHours       Float            @default(0)
  startDate         DateTime
  deadline          DateTime
  completionDate    DateTime?
  progress          Float            @default(0)
  healthStatus      String           @default("HEALTHY")
  projectManagerId  String           @db.Uuid
  projectManager    User             @relation("ProjectManager", fields: [projectManagerId], references: [id])
  createdBy         String           @db.Uuid
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  archivedAt        DateTime?
  deletedAt         DateTime?

  teamMembers       ProjectTeam[]
  milestones        Milestone[]
  notes             ProjectNote[]
  files             ProjectFile[]
  meetings          ProjectMeeting[]
  deployments       ProjectDeployment[]
  activities        ProjectActivity[]
  tasks             Task[]
  timeLogs          TimeLog[]
  meetingsLinked    Meeting[]
  calendarEvents    CalendarEvent[]

  @@index([clientId])
  @@index([projectManagerId])
  @@index([status])
  @@index([deletedAt])
  @@index([archivedAt])
}

model ProjectTeam {
  projectId  String   @db.Uuid
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId     String   @db.Uuid
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       String
  joinedDate DateTime @default(now())

  @@id([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model Milestone {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime
  status      String   @default("PENDING")
  progress    Float    @default(0)
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([status])
}

model ProjectNote {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  note      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([userId])
}

model ProjectFile {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  type      String
  size      Int
  url       String
  folder    String   @default("DOCUMENTS") // Design, Source Code, Contracts, Assets, Documents, Deliverables
  createdAt DateTime @default(now())

  @@index([projectId])
}

model ProjectMeeting {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  date        DateTime
  participants String
  platform    String
  notes       String?  @db.Text
  actionItems String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([projectId])
}

model ProjectDeployment {
  id              String   @id @default(uuid()) @db.Uuid
  projectId       String   @db.Uuid
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment     String
  repositoryUrl   String
  hostingProvider String
  branch          String
  commitHash      String?
  productionUrl   String?
  stagingUrl      String?
  status          String   @default("SUCCESS")
  version         String
  createdAt       DateTime @default(now())

  @@index([projectId])
}

model ProjectActivity {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        String
  description String
  createdAt   DateTime @default(now())

  @@index([projectId])
}

model Task {
  id              String           @id @default(uuid()) @db.Uuid
  projectId       String           @db.Uuid
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentTaskId    String?          @db.Uuid
  parentTask      Task?            @relation("Subtasks", fields: [parentTaskId], references: [id])
  subtasks        Task[]           @relation("Subtasks")
  title           String
  description     String?          @db.Text
  status          String           @default("TODO")
  priority        String           @default("MEDIUM")
  estimatedHours  Float            @default(0)
  actualHours     Float            @default(0)
  storyPoints     Int?
  startDate       DateTime?
  dueDate         DateTime?
  completedAt     DateTime?
  position        Float            @default(0)
  createdBy       String           @db.Uuid
  updatedBy       String?          @db.Uuid
  createdAt       DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt       DateTime?

  assignees       User[]           @relation("TaskAssignees")
  comments        TaskComment[]
  checklist       TaskChecklist[]
  attachments     TaskAttachment[]
  activities      TaskActivity[]
  labels          TaskLabel[]      @relation("TaskLabels")
  timeLogs        TimeLog[]

  @@index([projectId])
  @@index([parentTaskId])
  @@index([status])
  @@index([deletedAt])
}

model TaskComment {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @db.Uuid
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  comment   String   @db.Text
  edited    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([userId])
}

model TaskChecklist {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @db.Uuid
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title     String
  completed Boolean  @default(false)
  order     Int      @default(0)

  @@index([taskId])
}

model TaskAttachment {
  id           String   @id @default(uuid()) @db.Uuid
  taskId       String   @db.Uuid
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  name         String
  url          String
  size         Int
  uploadedById String   @db.Uuid
  uploadedBy   User     @relation("TaskAttachmentUploader", fields: [uploadedById], references: [id])
  uploadedAt   DateTime @default(now())

  @@index([taskId])
  @@index([uploadedById])
}

model TaskLabel {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  color     String   @default("#3B82F6")
  tasks     Task[]   @relation("TaskLabels")
}

model TaskActivity {
  id          String   @id @default(uuid()) @db.Uuid
  taskId      String   @db.Uuid
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type        String
  description String
  createdAt   DateTime @default(now())

  @@index([taskId])
}

model TimeLog {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @db.Uuid
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId          String    @db.Uuid
  project            Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId             String?   @db.Uuid
  task               Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  description        String
  startTime          DateTime
  endTime            DateTime?
  duration           Float     @default(0)
  billable           Boolean   @default(true)
  hourlyRateSnapshot Float
  status             String    @default("DRAFT") // Draft, Submitted, Approved, Rejected
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId])
  @@index([projectId])
  @@index([taskId])
  @@index([status])
}

model Meeting {
  id           String               @id @default(uuid()) @db.Uuid
  projectId    String?              @db.Uuid
  project      Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title        String
  description  String?              @db.Text
  startTime    DateTime
  endTime      DateTime
  meetingType  String               @default("INTERNAL") // Internal, Client, Sprint Planning, Review, Stand-up, Demo
  platform     String               @default("GOOGLE_MEET") // Google Meet, Zoom, Microsoft Teams, In Person, Custom
  meetingLink  String
  organizerId  String               @db.Uuid
  organizer    User                 @relation("OrganizerMeetings", fields: [organizerId], references: [id])
  createdAt    DateTime             @default(now())
  participants MeetingParticipant[]

  @@index([projectId])
  @@index([organizerId])
}

model MeetingParticipant {
  meetingId        String   @db.Uuid
  meeting          Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId           String   @db.Uuid
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  attendanceStatus String   @default("INVITED") // Invited, Accepted, Declined, Attended

  @@id([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
}

model CalendarEvent {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  description String?  @db.Text
  eventType   String   @default("REMINDER") // Meeting, Deadline, Reminder, Leave, Holiday, Task Due Date
  startTime   DateTime
  endTime     DateTime
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String?  @db.Uuid
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
}

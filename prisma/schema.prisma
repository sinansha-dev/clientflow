generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
  CLIENT
}

enum ProjectRole {
  PROJECT_MANAGER
  LEAD_DEVELOPER
  DEVELOPER
  DESIGNER
  QA
  VIEWER
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

model User {
  id                          String               @id @default(uuid()) @db.Uuid
  firstName                   String
  lastName                    String
  email                       String               @unique
  password                    String
  avatar                      String?
  phone                       String?
  role                        Role                 @default(CLIENT)
  status                      UserStatus           @default(ACTIVE)
  emailVerified               Boolean              @default(false)
  lastLogin                   DateTime?
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  deletedAt                   DateTime?
  refreshTokens               RefreshToken[]
  resetTokens                 PasswordResetToken[]
  managedClients              Client[]             @relation("ManagerClients")
  clientNotes                 ClientNote[]
  assignedProjects            ProjectMember[]      @relation("AssignedProjects")
  createdMembers              ProjectMember[]      @relation("AssignedByMember")
  managedProjects             Project[]            @relation("ProjectManager")
  projectNotes                ProjectNote[]
  assignedTasks               Task[]               @relation("TaskAssignees")
  taskComments                TaskComment[]
  taskAttachments             TaskAttachment[]     @relation("TaskAttachmentUploader")
  portalAccesses              ClientPortalAccess[]
  uploadedProjectFiles        ProjectFile[]        @relation("ProjectFileUploader")
  uploadedProjectFileVersions ProjectFileVersion[] @relation("ProjectFileVersionUploader")
  portalMessages              PortalMessage[]
  portalActivities            PortalActivity[]
  revisionRequests            RevisionRequest[]
  fileDownloads               FileDownload[]
  createdQuotations           Quotation[]          @relation("QuotationCreator")
  createdInvoices             Invoice[]            @relation("InvoiceCreator")
  recordedPayments            Payment[]            @relation("PaymentRecorder")
  recordedExpenses            Expense[]            @relation("ExpenseRecorder")
  invoiceActivities           InvoiceActivity[]    @relation("InvoiceUserActivities")
  createdNotifications        Notification[]       @relation("NotificationCreator")
  notifications               NotificationRecipient[] @relation("UserNotifications")
  notificationPreference      NotificationPreference?
  // Workforce Management fields (Phase 5)
  employeeId                  String?
  jobTitle                    String?
  department                  String?
  skills                      String[]
  hourlyRate                  Float?
  employmentType              String? // Full-Time, Part-Time, Freelancer, Contractor
  joinDate                    DateTime?
  managerId                   String?              @db.Uuid
  manager                     User?                @relation("UserManager", fields: [managerId], references: [id])
  subordinates                User[]               @relation("UserManager")
  availabilityStatus          String               @default("OFFLINE") // Available, Busy, In Meeting, On Leave, Offline
  timezone                    String               @default("UTC")

  timeLogs          TimeLog[]
  meetingsOrganized Meeting[]            @relation("OrganizerMeetings")
  meetingsAttending MeetingParticipant[]
  calendarEvents    CalendarEvent[]

  @@index([email])
  @@index([role])
  @@index([deletedAt])
}

model RefreshToken {
  id                  String    @id @default(uuid()) @db.Uuid
  tokenHash           String    @unique
  userId              String    @db.Uuid
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt           DateTime
  revokedAt           DateTime?
  createdAt           DateTime  @default(now())
  replacedByTokenHash String?

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Client {
  id                String    @id @default(uuid()) @db.Uuid
  companyName       String    @unique
  companyLogo       String?
  industry          String
  website           String
  email             String
  phone             String
  taxNumber         String?
  billingAddress    String
  shippingAddress   String
  country           String
  state             String
  city              String
  postalCode        String
  currency          String    @default("USD")
  timezone          String    @default("UTC")
  status            String    @default("ACTIVE")
  source            String?
  assignedManagerId String?   @db.Uuid
  assignedManager   User?     @relation("ManagerClients", fields: [assignedManagerId], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  archivedAt        DateTime?
  deletedAt         DateTime?

  contacts             ClientContact[]
  notes                ClientNote[]
  files                ClientFile[]
  activities           ClientActivity[]
  projects             Project[]
  portalAccesses       ClientPortalAccess[]
  deliverableApprovals DeliverableApproval[]
  quotations           Quotation[]
  invoices             Invoice[]
  payments             Payment[]

  @@index([deletedAt])
  @@index([archivedAt])
  @@index([companyName])
}

model ClientContact {
  id             String   @id @default(uuid()) @db.Uuid
  clientId       String   @db.Uuid
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name           String
  position       String
  email          String
  phone          String
  whatsapp       String?
  primaryContact Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([clientId])
}

model ClientNote {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @db.Uuid
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  note      String   @db.Text
  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([userId])
}

model ClientFile {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @db.Uuid
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  type      String
  size      Int
  url       String
  createdAt DateTime @default(now())

  @@index([clientId])
}

model ClientActivity {
  id          String   @id @default(uuid()) @db.Uuid
  clientId    String   @db.Uuid
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type        String
  description String
  createdAt   DateTime @default(now())

  @@index([clientId])
}

model Project {
  id               String    @id @default(uuid()) @db.Uuid
  clientId         String    @db.Uuid
  client           Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectName      String
  projectCode      String    @unique
  description      String
  status           String    @default("PLANNING")
  priority         String    @default("MEDIUM")
  budget           Float
  estimatedHours   Float
  actualHours      Float     @default(0)
  startDate        DateTime
  deadline         DateTime
  completionDate   DateTime?
  progress         Float     @default(0)
  healthStatus     String    @default("HEALTHY")
  projectManagerId String    @db.Uuid
  projectManager   User      @relation("ProjectManager", fields: [projectManagerId], references: [id])
  createdBy        String    @db.Uuid
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  archivedAt       DateTime?
  deletedAt        DateTime?

  projectMembers       ProjectMember[]
  milestones           Milestone[]
  notes                ProjectNote[]
  files                ProjectFile[]
  meetings             ProjectMeeting[]
  deployments          ProjectDeployment[]
  activities           ProjectActivity[]
  tasks                Task[]
  timeLogs             TimeLog[]
  meetingsLinked       Meeting[]
  calendarEvents       CalendarEvent[]
  portalFolders        PortalFolder[]
  deliverableApprovals DeliverableApproval[]
  revisionRequests     RevisionRequest[]
  portalMessages       PortalMessage[]
  portalActivities     PortalActivity[]
  quotations           Quotation[]
  invoices             Invoice[]
  expenses             Expense[]
  billingPlan          BillingPlan?
  recurringServices    RecurringService[]

  @@index([clientId])
  @@index([projectManagerId])
  @@index([status])
  @@index([deletedAt])
  @@index([archivedAt])
}

model ProjectMember {
  id           String      @id @default(uuid()) @db.Uuid
  projectId    String      @db.Uuid
  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId       String      @db.Uuid
  user         User        @relation("AssignedProjects", fields: [userId], references: [id], onDelete: Cascade)
  projectRole  ProjectRole
  joinedAt     DateTime    @default(now())
  assignedById String?     @db.Uuid
  assignedBy   User?       @relation("AssignedByMember", fields: [assignedById], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model Milestone {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime
  status      String   @default("PENDING")
  progress    Float    @default(0)
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([status])
}

model ProjectNote {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  note      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([userId])
}

model ProjectFile {
  id                 String                    @id @default(uuid()) @db.Uuid
  projectId          String                    @db.Uuid
  project            Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folderId           String?                   @db.Uuid
  folderNode         PortalFolder?             @relation(fields: [folderId], references: [id], onDelete: SetNull)
  name               String
  originalFileName   String?
  type               String
  size               Int
  url                String
  storagePath        String?
  folder             String                    @default("DOCUMENTS")
  uploadedById       String?                   @db.Uuid
  uploadedBy         User?                     @relation("ProjectFileUploader", fields: [uploadedById], references: [id])
  version            Int                       @default(1)
  visibility         String                    @default("INTERNAL")
  downloadCount      Int                       @default(0)
  deliverableStatus  String                    @default("DRAFT")
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  deletedAt          DateTime?
  versions           ProjectFileVersion[]
  approvals          DeliverableApproval[]     @relation("DeliverableApprovals")
  revisionRequests   RevisionRequest[]         @relation("DeliverableRevisions")
  downloadLogs       FileDownload[]
  messageAttachments PortalMessageAttachment[]

  @@index([projectId])
  @@index([folderId])
  @@index([uploadedById])
  @@index([visibility])
  @@index([deliverableStatus])
  @@index([deletedAt])
}

model ProjectMeeting {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @db.Uuid
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title        String
  date         DateTime
  participants String
  platform     String
  notes        String?  @db.Text
  actionItems  String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([projectId])
}

model ProjectDeployment {
  id              String   @id @default(uuid()) @db.Uuid
  projectId       String   @db.Uuid
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment     String
  repositoryUrl   String
  hostingProvider String
  branch          String
  commitHash      String?
  productionUrl   String?
  stagingUrl      String?
  status          String   @default("SUCCESS")
  version         String
  createdAt       DateTime @default(now())

  @@index([projectId])
}

model ProjectActivity {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        String
  description String
  createdAt   DateTime @default(now())

  @@index([projectId])
}

model Task {
  id             String    @id @default(uuid()) @db.Uuid
  projectId      String    @db.Uuid
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentTaskId   String?   @db.Uuid
  parentTask     Task?     @relation("Subtasks", fields: [parentTaskId], references: [id])
  subtasks       Task[]    @relation("Subtasks")
  title          String
  description    String?   @db.Text
  status         String    @default("TODO")
  priority       String    @default("MEDIUM")
  estimatedHours Float     @default(0)
  actualHours    Float     @default(0)
  storyPoints    Int?
  startDate      DateTime?
  dueDate        DateTime?
  completedAt    DateTime?
  position       Float     @default(0)
  createdBy      String    @db.Uuid
  updatedBy      String?   @db.Uuid
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  assignees   User[]           @relation("TaskAssignees")
  comments    TaskComment[]
  checklist   TaskChecklist[]
  attachments TaskAttachment[]
  activities  TaskActivity[]
  labels      TaskLabel[]      @relation("TaskLabels")
  timeLogs    TimeLog[]

  @@index([projectId])
  @@index([parentTaskId])
  @@index([status])
  @@index([deletedAt])
}

model TaskComment {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @db.Uuid
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  comment   String   @db.Text
  edited    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([userId])
}

model TaskChecklist {
  id        String  @id @default(uuid()) @db.Uuid
  taskId    String  @db.Uuid
  task      Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title     String
  completed Boolean @default(false)
  order     Int     @default(0)

  @@index([taskId])
}

model TaskAttachment {
  id           String   @id @default(uuid()) @db.Uuid
  taskId       String   @db.Uuid
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  name         String
  url          String
  size         Int
  uploadedById String   @db.Uuid
  uploadedBy   User     @relation("TaskAttachmentUploader", fields: [uploadedById], references: [id])
  uploadedAt   DateTime @default(now())

  @@index([taskId])
  @@index([uploadedById])
}

model TaskLabel {
  id    String @id @default(uuid()) @db.Uuid
  name  String @unique
  color String @default("#3B82F6")
  tasks Task[] @relation("TaskLabels")
}

model TaskActivity {
  id          String   @id @default(uuid()) @db.Uuid
  taskId      String   @db.Uuid
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type        String
  description String
  createdAt   DateTime @default(now())

  @@index([taskId])
}

model TimeLog {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @db.Uuid
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId          String    @db.Uuid
  project            Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId             String?   @db.Uuid
  task               Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  description        String
  startTime          DateTime
  endTime            DateTime?
  duration           Float     @default(0)
  billable           Boolean   @default(true)
  hourlyRateSnapshot Float
  status             String    @default("DRAFT") // Draft, Submitted, Approved, Rejected
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId])
  @@index([projectId])
  @@index([taskId])
  @@index([status])
}

model Meeting {
  id           String               @id @default(uuid()) @db.Uuid
  projectId    String?              @db.Uuid
  project      Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title        String
  description  String?              @db.Text
  startTime    DateTime
  endTime      DateTime
  meetingType  String               @default("INTERNAL") // Internal, Client, Sprint Planning, Review, Stand-up, Demo
  platform     String               @default("GOOGLE_MEET") // Google Meet, Zoom, Microsoft Teams, In Person, Custom
  meetingLink  String
  organizerId  String               @db.Uuid
  organizer    User                 @relation("OrganizerMeetings", fields: [organizerId], references: [id])
  createdAt    DateTime             @default(now())
  participants MeetingParticipant[]

  @@index([projectId])
  @@index([organizerId])
}

model MeetingParticipant {
  meetingId        String  @db.Uuid
  meeting          Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId           String  @db.Uuid
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  attendanceStatus String  @default("INVITED") // Invited, Accepted, Declined, Attended

  @@id([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
}

model CalendarEvent {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  description String?  @db.Text
  eventType   String   @default("REMINDER") // Meeting, Deadline, Reminder, Leave, Holiday, Task Due Date
  startTime   DateTime
  endTime     DateTime
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String?  @db.Uuid
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
}

model ClientPortalAccess {
  id        String    @id @default(uuid()) @db.Uuid
  clientId  String    @db.Uuid
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastLogin DateTime?
  status    String    @default("PENDING_INVITATION")
  createdAt DateTime  @default(now())

  @@unique([clientId, userId])
  @@index([clientId])
  @@index([userId])
  @@index([status])
}

model PortalFolder {
  id             String         @id @default(uuid()) @db.Uuid
  projectId      String         @db.Uuid
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentFolderId String?        @db.Uuid
  parentFolder   PortalFolder?  @relation("PortalFolderTree", fields: [parentFolderId], references: [id], onDelete: Cascade)
  childFolders   PortalFolder[] @relation("PortalFolderTree")
  folderName     String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  files          ProjectFile[]

  @@unique([projectId, parentFolderId, folderName])
  @@index([projectId])
  @@index([parentFolderId])
  @@index([deletedAt])
}

model ProjectFileVersion {
  id               String      @id @default(uuid()) @db.Uuid
  fileId           String      @db.Uuid
  file             ProjectFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  version          Int
  fileName         String
  originalFileName String
  fileType         String
  fileSize         Int
  storagePath      String
  uploadedById     String      @db.Uuid
  uploadedBy       User        @relation("ProjectFileVersionUploader", fields: [uploadedById], references: [id])
  createdAt        DateTime    @default(now())

  @@unique([fileId, version])
  @@index([fileId])
  @@index([uploadedById])
}

model DeliverableApproval {
  id            String      @id @default(uuid()) @db.Uuid
  projectId     String      @db.Uuid
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliverableId String      @db.Uuid
  deliverable   ProjectFile @relation("DeliverableApprovals", fields: [deliverableId], references: [id], onDelete: Cascade)
  clientId      String      @db.Uuid
  client        Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  status        String      @default("PENDING")
  comments      String?     @db.Text
  approvedAt    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([projectId])
  @@index([deliverableId])
  @@index([clientId])
  @@index([status])
}

model RevisionRequest {
  id            String      @id @default(uuid()) @db.Uuid
  projectId     String      @db.Uuid
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliverableId String      @db.Uuid
  deliverable   ProjectFile @relation("DeliverableRevisions", fields: [deliverableId], references: [id], onDelete: Cascade)
  requestedById String      @db.Uuid
  requestedBy   User        @relation(fields: [requestedById], references: [id])
  description   String      @db.Text
  priority      String      @default("MEDIUM")
  status        String      @default("OPEN")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([projectId])
  @@index([deliverableId])
  @@index([requestedById])
  @@index([status])
}

model PortalMessage {
  id           String                    @id @default(uuid()) @db.Uuid
  projectId    String                    @db.Uuid
  project      Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId     String                    @db.Uuid
  author       User                      @relation(fields: [authorId], references: [id])
  body         String                    @db.Text
  internalOnly Boolean                   @default(false)
  edited       Boolean                   @default(false)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  deletedAt    DateTime?
  attachments  PortalMessageAttachment[]

  @@index([projectId])
  @@index([authorId])
  @@index([internalOnly])
  @@index([deletedAt])
}

model PortalMessageAttachment {
  id        String        @id @default(uuid()) @db.Uuid
  messageId String        @db.Uuid
  message   PortalMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileId    String?       @db.Uuid
  file      ProjectFile?  @relation(fields: [fileId], references: [id], onDelete: SetNull)
  name      String
  url       String
  fileType  String
  fileSize  Int
  createdAt DateTime      @default(now())

  @@index([messageId])
  @@index([fileId])
}

model PortalActivity {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String?  @db.Uuid
  user        User?    @relation(fields: [userId], references: [id])
  type        String
  description String
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([userId])
  @@index([type])
}

model FileDownload {
  id        String      @id @default(uuid()) @db.Uuid
  fileId    String      @db.Uuid
  file      ProjectFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  userId    String      @db.Uuid
  user      User        @relation(fields: [userId], references: [id])
  createdAt DateTime    @default(now())

  @@index([fileId])
  @@index([userId])
  @@index([createdAt])
}

model Quotation {
  id                String          @id @default(uuid()) @db.Uuid
  quoteNumber       String          @unique
  clientId          String          @db.Uuid
  client            Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId         String?         @db.Uuid
  project           Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title             String
  description       String?         @db.Text
  quoteDate         DateTime        @default(now())
  validUntil        DateTime
  currency          String          @default("USD")
  status            String          @default("DRAFT")
  subtotal          Float           @default(0)
  tax               Float           @default(0)
  discount          Float           @default(0)
  total             Float           @default(0)
  notes             String?         @db.Text
  scope             String?         @db.Text
  termsConditions   String?         @db.Text
  internalNotes     String?         @db.Text
  billingPlanDraft  Json?
  attachments       Json?
  createdBy         String          @db.Uuid
  creator           User            @relation("QuotationCreator", fields: [createdBy], references: [id])
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?
  items             QuotationItem[]

  @@index([clientId])
  @@index([projectId])
  @@index([status])
  @@index([deletedAt])
}

model QuotationItem {
  id          String    @id @default(uuid()) @db.Uuid
  quotationId String    @db.Uuid
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  name        String
  description String?   @db.Text
  quantity    Float
  unitPrice   Float
  taxRate     Float     @default(0)
  total       Float
  createdAt   DateTime  @default(now())

  @@index([quotationId])
}

model Invoice {
  id                  String        @id @default(uuid()) @db.Uuid
  invoiceNumber       String        @unique
  clientId            String        @db.Uuid
  client              Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId           String?       @db.Uuid
  project             Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title               String        @default("Invoice")
  scope               String?       @db.Text
  issueDate           DateTime
  dueDate             DateTime
  status              String        @default("DRAFT")
  currency            String        @default("USD")
  subtotal            Float         @default(0)
  tax                 Float         @default(0)
  discount            Float         @default(0)
  total               Float         @default(0)
  amountPaid          Float         @default(0)
  balanceDue          Float         @default(0)
  notes               String?       @db.Text
  termsConditions     String?       @db.Text
  internalNotes       String?       @db.Text
  attachments         Json?
  paymentMethod       String?
  paymentInstructions String?       @db.Text
  createdBy           String        @db.Uuid
  creator             User          @relation("InvoiceCreator", fields: [createdBy], references: [id])
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?
  items               InvoiceItem[]
  payments            Payment[]
  billingStageId      String?       @unique @db.Uuid
  billingStage        BillingStage? @relation(fields: [billingStageId], references: [id], onDelete: SetNull)
  type                InvoiceType   @default(PROJECT)
  billingPeriodFrom   DateTime?
  billingPeriodTo     DateTime?
  recurringServiceId  String?       @db.Uuid
  recurringService    RecurringService? @relation(fields: [recurringServiceId], references: [id], onDelete: SetNull)
  originalInvoiceId   String?       @db.Uuid
  originalInvoice     Invoice?      @relation("InvoiceRevisions", fields: [originalInvoiceId], references: [id], onDelete: SetNull)
  revisions           Invoice[]     @relation("InvoiceRevisions")
  revisionNumber      Int           @default(0)
  activities          InvoiceActivity[]

  @@index([clientId])
  @@index([projectId])
  @@index([status])
  @@index([deletedAt])
  @@index([originalInvoiceId])
}

model InvoiceItem {
  id          String   @id @default(uuid()) @db.Uuid
  invoiceId   String   @db.Uuid
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.Text
  quantity    Float
  unitPrice   Float
  taxRate     Float    @default(0)
  total       Float
  createdAt   DateTime @default(now())

  @@index([invoiceId])
}

model Payment {
  id              String   @id @default(uuid()) @db.Uuid
  invoiceId       String   @db.Uuid
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  clientId        String   @db.Uuid
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  amount          Float
  paymentMethod   String
  referenceNumber String?
  paymentDate     DateTime
  notes           String?  @db.Text
  recordedBy      String   @db.Uuid
  recorder        User     @relation("PaymentRecorder", fields: [recordedBy], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([invoiceId])
  @@index([clientId])
  @@index([paymentDate])
}

model Expense {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @db.Uuid
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category    String
  amount      Float
  description String    @db.Text
  receiptUrl  String?
  expenseDate DateTime
  recordedBy  String    @db.Uuid
  recorder    User      @relation("ExpenseRecorder", fields: [recordedBy], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([projectId])
  @@index([recordedBy])
  @@index([expenseDate])
  @@index([deletedAt])
}

enum InvoiceType {
  PROJECT
  ADVANCE
  MILESTONE
  FINAL
  RECURRING
  CREDIT_NOTE
}

enum BillingPlanType {
  FULL_PAYMENT
  ADVANCE_BALANCE
  MILESTONE
  MONTHLY_RETAINER
  AMC
  CUSTOM
}

enum RecurringServiceInterval {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum RecurringServiceStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

model BillingPlan {
  id          String          @id @default(uuid()) @db.Uuid
  projectId   String          @unique @db.Uuid
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  billingType BillingPlanType
  totalAmount Float           @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  stages BillingStage[]
}

model BillingStage {
  id            String      @id @default(uuid()) @db.Uuid
  billingPlanId String      @db.Uuid
  billingPlan   BillingPlan @relation(fields: [billingPlanId], references: [id], onDelete: Cascade)
  name          String
  amount        Float
  dueDate       DateTime?
  status        String      @default("PENDING")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  invoice Invoice?
}

model RecurringService {
  id               String                   @id @default(uuid()) @db.Uuid
  projectId        String                   @db.Uuid
  project          Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name             String
  amount           Float
  interval         RecurringServiceInterval
  status           RecurringServiceStatus   @default(ACTIVE)
  startDate        DateTime
  nextInvoiceDate  DateTime
  lastInvoicedDate DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  invoices         Invoice[]

  @@index([projectId])
}

model InvoiceActivity {
  id          String   @id @default(uuid()) @db.Uuid
  invoiceId   String   @db.Uuid
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  userId      String?  @db.Uuid
  user        User?    @relation("InvoiceUserActivities", fields: [userId], references: [id], onDelete: SetNull)
  action      String   // e.g. CREATED, EDITED, SENT, VIEWED, RESENT, VOIDED, REVISION_CREATED
  description String
  createdAt   DateTime @default(now())

  @@index([invoiceId])
  @@index([userId])
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  SYSTEM
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

model Notification {
  id            String                @id @default(uuid()) @db.Uuid
  type          NotificationType      @default(INFO)
  event         String
  title         String
  message       String
  data          Json?
  priority      NotificationPriority  @default(NORMAL)
  status        String                @default("PROCESSED") // PENDING, PROCESSED, FAILED, PARTIAL
  createdBy     String?               @db.Uuid
  createdByUser User?                 @relation("NotificationCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  recipients    NotificationRecipient[]

  @@index([event])
  @@index([type])
  @@index([priority])
  @@index([createdAt])
}

model NotificationRecipient {
  id             String       @id @default(uuid()) @db.Uuid
  notificationId String       @db.Uuid
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId         String       @db.Uuid
  user           User         @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  isRead         Boolean      @default(false)
  readAt         DateTime?
  isArchived     Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([userId])
  @@index([notificationId])
  @@index([userId, isRead])
  @@index([userId, isArchived])
}

model EmailLog {
  id        String    @id @default(uuid()) @db.Uuid
  recipient String
  subject   String
  provider  String
  status    String    // SENT, FAILED
  error     String?
  sentAt    DateTime?
  attempts  Int       @default(1)
  messageId String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([recipient])
  @@index([status])
  @@index([createdAt])
}

model NotificationPreference {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailEnabled Boolean  @default(true)
  inAppEnabled Boolean  @default(true)
  pushEnabled  Boolean  @default(true)
  smsEnabled   Boolean  @default(false)
  language     String   @default("en")
  timezone     String   @default("UTC")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

